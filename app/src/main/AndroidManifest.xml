<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Notification Listener Permission -->
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE" />
    
    <!-- Foreground Service Permission -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    
    <!-- Wake Lock for background processing -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- Vibration for urgent notifications -->
    <uses-permission android:name="android.permission.VIBRATE" />
    
    <!-- Post notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    
    <!-- Usage Stats Permission (for screen time tracking) -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" tools:ignore="ProtectedPermissions" />

    <application
        android:name=".NotifyrApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Notifyr">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Notifyr">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- Notification Listener Service -->
        <service
            android:name=".service.NotificationListenerService"
            android:exported="false"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>
        
        <!-- Notification Action Receiver -->
        <receiver
            android:name=".service.NotificationActionReceiver"
            android:exported="false" />
        
        <!-- Notification Widget Provider -->
        <receiver
            android:name=".widget.NotificationWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.javohirmx.notifyr.widget.ACTION_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/notification_widget_info" />
        </receiver>
        
        <!-- Screen Time Widget Provider -->
        <receiver
            android:name=".widget.ScreenTimeWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.javohirmx.notifyr.widget.ACTION_REFRESH_SCREENTIME" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/screentime_widget_info" />
        </receiver>
        
        <!-- Notification Widget Update Service -->
        <service
            android:name=".widget.NotificationWidgetUpdateService"
            android:exported="false" />
        
        <!-- Screen Time Widget Update Service -->
        <service
            android:name=".widget.ScreenTimeWidgetUpdateService"
            android:exported="false" />
        
        <!-- Notification Widget Configuration Activity -->
        <activity
            android:name=".widget.NotificationWidgetConfigureActivity"
            android:exported="false"
            android:theme="@style/Theme.Notifyr">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>
        
        <!-- Screen Time Widget Configuration Activity -->
        <activity
            android:name=".widget.ScreenTimeWidgetConfigureActivity"
            android:exported="false"
            android:theme="@style/Theme.Notifyr">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE" />
            </intent-filter>
        </activity>
            
        <!-- Remove the default WorkManager initializer since we implement Configuration.Provider -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>

</manifest>